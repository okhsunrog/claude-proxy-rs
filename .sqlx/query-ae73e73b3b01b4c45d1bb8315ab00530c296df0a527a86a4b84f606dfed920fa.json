  "query": "SELECT (created_at / $1) * $1 AS bucket, COUNT(*) AS \"request_count!\", COALESCE(SUM(cost_microdollars), 0)::BIGINT AS \"cost_microdollars!\", COALESCE(SUM(input_tokens), 0)::BIGINT AS \"input_tokens!\", COALESCE(SUM(output_tokens), 0)::BIGINT AS \"output_tokens!\", COALESCE(SUM(cache_read_tokens), 0)::BIGINT AS \"cache_read_tokens!\", COALESCE(SUM(cache_write_tokens), 0)::BIGINT AS \"cache_write_tokens!\" FROM request_log WHERE key_id = $3 AND created_at >= $2 GROUP BY bucket ORDER BY bucket",
